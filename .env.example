# Название приложения для API, логов и health check.
APP_NAME=devreach-ai

# Окружение запуска: local, test, staging или production.
APP_ENV=local

# Включает подробные ошибки FastAPI в локальной разработке.
DEBUG=false

# Хост локального запуска Uvicorn.
HOST=127.0.0.1

# Порт локального запуска Uvicorn.
PORT=8000

# Локальная SQLite база. Не используйте production URL в тестах.
DATABASE_URL=sqlite:///./devreach_ai.sqlite3

# Разрешённые CORS origins через запятую. Для локального этапа можно оставить localhost.
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Уровень логирования приложения.
LOG_LEVEL=INFO

# Путь к файлу логов. Каталог создаётся автоматически.
LOG_FILE_PATH=logs/app.log

# Максимальный размер одного файла логов в байтах.
LOG_MAX_BYTES=1048576

# Количество резервных файлов при ротации.
LOG_BACKUP_COUNT=3

# Ключ ProxyAPI для live AI-проверок через OpenAI SDK.
# В реальный .env добавляется вручную, секрет не хранится в коде.
# Прямой ключ OpenAI не используем локально из-за регионального ограничения unsupported_country_region_territory.
OPENAI_API_KEY=

# Базовый URL ProxyAPI для OpenAI SDK.
OPENAI_BASE_URL=https://api.proxyapi.ru/openai/v1

# Модель OpenAI, доступная через ProxyAPI, со structured output для анализа обращений.
OPENAI_MODEL=gpt-4.1-mini

# Таймаут одного AI-запроса в секундах.
OPENAI_TIMEOUT_SECONDS=20

# Количество retry, передаваемое официальному OpenAI SDK.
OPENAI_MAX_RETRIES=1

# Защита от случайных live-вызовов и расхода токенов.
AI_LIVE_REQUESTS_ENABLED=false

# Количество попыток POST /api/contact с одного клиента за окно.
CONTACT_RATE_LIMIT_REQUESTS=3

# Размер sliding window для POST /api/contact в секундах.
CONTACT_RATE_LIMIT_WINDOW_SECONDS=600

# Доверять X-Forwarded-For от reverse proxy Render при определении IP клиента.
TRUST_PROXY_HEADERS=true

# Resend API key для live email-проверок. В реальный .env добавляется вручную, секрет не хранится в коде.
RESEND_API_KEY=

# Чистый email отправителя из подтверждённого домена Resend.
# Не указывайте здесь имя в формате "Name <email@example.com>" — имя задаётся в EMAIL_FROM_NAME.
EMAIL_FROM_ADDRESS=

# Имя отправителя, отображаемое в письмах.
EMAIL_FROM_NAME=DevReach AI

# Email владельца сайта для уведомлений о новых обращениях.
OWNER_EMAIL=

# Защита от случайной отправки реальных писем.
EMAIL_LIVE_REQUESTS_ENABLED=false

# Reply-To для ручных тестовых email-команд. В owner notification используется email пользователя из обращения.
EMAIL_REPLY_TO=

# Префикс темы письма владельцу.
EMAIL_SUBJECT_PREFIX=[DevReach AI]

# Секретный токен защищённого демонстрационного режима.
# Если значение пустое, отправка результата на адрес проверяющего отключена.
# Реальное значение хранится только в локальном .env или настройках Render.
DEMO_ACCESS_TOKEN=
